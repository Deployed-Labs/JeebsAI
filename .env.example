# Example env for docker-compose
PORT=8080
DATABASE_URL=sqlite:/data/jeebs.db
RUST_LOG=info
# Set your domain for Traefik to route (e.g. jeebs.club)
DOMAIN=jeebs.club
# Email for Let's Encrypt registration
TRAEFIK_ACME_EMAIL=you@example.com
# Optional: base64 session key to persist sessions across restarts
# Generate with: python3 -c "import os,base64; print(base64.b64encode(os.urandom(64)).decode())"
SESSION_KEY_B64=
# JeebsAI Environment Configuration
# Copy this file to /etc/jeebs.env on production or .env for local development

# ============================================
# Server Configuration
# ============================================

# Port for the web server to listen on
# Default: 8080 (Nginx will proxy to this port in production)
PORT=8080

# ============================================
# Database Configuration
# ============================================

# SQLite database path
# Use absolute path for production, relative for development
DATABASE_URL=sqlite:jeebs.db

# ============================================
# Logging Configuration
# ============================================

# Logging level for the application
# Options: error, warn, info, debug, trace
# Uncomment to enable detailed logging
# RUST_LOG=info,actix_web=info

# ============================================
# Security Configuration (Optional)
# ============================================

# Session secret key (auto-generated if not set)
# SESSION_SECRET=your-secret-key-here

# ============================================
# Production Configuration
# ============================================

# Set to 'production' to enable production optimizations
# ENVIRONMENT=production

# ============================================
# API Keys (Optional - if integrating external services)
# ============================================

# Add any external API keys here
# OPENAI_API_KEY=your-key-here
# ANTHROPIC_API_KEY=your-key-here
